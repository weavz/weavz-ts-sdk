{
  "name": "@weavz/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Weavz API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "openapi-ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/",
    "test:watch": "vitest tests/"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.97.1",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.6"
  },
  "keywords": [
    "weavz",
    "sdk",
    "api",
    "integrations",
    "ipaas",
    "mcp"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/weavz/weavz",
    "directory": "sdks/typescript"
  }
}
